{
  "name": "@voice-agent-kit/core",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.22.4",
    "uuid": "^14.0.0",
    "debug": "^4.3.4",
    "@opentelemetry/api": "^1.7.0"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/uuid": "^9.0.7",
    "vitest": "^1.3.0",
    "@vitest/coverage-v8": "^1.3.0"
  },
  "peerDependencies": {
    "typescript": "^5.3.0"
  }
}
