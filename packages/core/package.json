{
  "name": "@reaatech/voice-agent-core",
  "version": "0.1.0",
  "description": "Core pipeline orchestration, session management, latency enforcement, configuration, and types for building voice-enabled AI agents",
  "license": "MIT",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reaatech/voice-agent-kit.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/reaatech/voice-agent-kit/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/reaatech/voice-agent-kit/issues"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "debug": "^4.3.4",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@aws-sdk/client-s3": ">=3.0.0",
    "@opentelemetry/api": "^1.7.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-s3": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aws-sdk/client-s3": ">=3.0.0",
    "@types/node": "^26.0.0",
    "@opentelemetry/api": "^1.7.0",
    "@types/debug": "^4.1.12",
    "@types/uuid": "^11.0.0",
    "@vitest/coverage-v8": "^1.3.0",
    "tsup": "^8.5.1",
    "vitest": "^1.3.0"
  }
}
