{
  "name": "@reaatech/voice-agent-tts",
  "version": "0.1.0",
  "description": "Provider-agnostic text-to-speech interface with Deepgram Aura, AWS Polly, and Google Cloud Text-to-Speech adapters",
  "license": "MIT",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reaatech/voice-agent-kit.git",
    "directory": "packages/tts"
  },
  "homepage": "https://github.com/reaatech/voice-agent-kit/tree/main/packages/tts#readme",
  "bugs": {
    "url": "https://github.com/reaatech/voice-agent-kit/issues"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@reaatech/voice-agent-core": "workspace:*",
    "debug": "^4.3.4",
    "ws": "^8.20.1"
  },
  "peerDependencies": {
    "@aws-sdk/client-polly": "^3.1031.0",
    "@aws-sdk/credential-provider-ini": "^3.972.43",
    "@google-cloud/text-to-speech": "^6.4.1"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-polly": {
      "optional": true
    },
    "@aws-sdk/credential-provider-ini": {
      "optional": true
    },
    "@google-cloud/text-to-speech": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@aws-sdk/client-polly": "^3.1031.0",
    "@aws-sdk/credential-provider-ini": "^3.972.43",
    "@google-cloud/text-to-speech": "^6.4.1",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^1.3.0",
    "tsup": "^8.5.1",
    "vitest": "^1.3.0"
  }
}
