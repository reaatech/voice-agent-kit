{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "pretty": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@voice-agent-kit/core": ["packages/core/src/index.ts"],
      "@voice-agent-kit/stt": ["packages/stt/src/index.ts"],
      "@voice-agent-kit/tts": ["packages/tts/src/index.ts"],
      "@voice-agent-kit/telephony": ["packages/telephony/src/index.ts"],
      "@voice-agent-kit/mcp-client": ["packages/mcp-client/src/index.ts"]
    }
  },
  "include": [
    "packages/**/src/**/*.ts",
    "examples/**/src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/dist/**",
    "**/coverage/**"
  ]
}
